package com.virtuaalpet.virtualpet;

import javafx.event.ActionEvent;
import javafx.fxml.FXML;
import javafx.fxml.FXMLLoader;
import javafx.scene.Parent;
import javafx.scene.Scene;
import javafx.stage.Stage;

import java.io.IOException;

public class TutorialScreenController {

    @FXML
    private void handleNextButton(ActionEvent event) {
        System.out.println("🟢 NEXT button clicked!");  // Debugging log

        try {
            FXMLLoader loader = new FXMLLoader(getClass().getResource("/com/virtuaalpet/virtualpet/tutorial_screen2.fxml"));
            Parent root = loader.load();

            Stage stage = (Stage) ((javafx.scene.Node) event.getSource()).getScene().getWindow();
            stage.setScene(new Scene(root));
            stage.show();

            System.out.println("✅ Tutorial Screen 2 loaded successfully!");
        } catch (IOException e) {
            System.err.println("❌ Error loading tutorial_screen2.fxml:");
            e.printStackTrace();
        }
    }

    @FXML
    private void handleBackButton(ActionEvent event) {
        System.out.println("🔵 BACK button clicked!");

        try {
            FXMLLoader loader = new FXMLLoader(getClass().getResource("/com/virtuaalpet/virtualpet/play_screen.fxml"));
            Parent root = loader.load();

            Stage stage = (Stage) ((javafx.scene.Node) event.getSource()).getScene().getWindow();
            stage.setScene(new Scene(root));
            stage.show();

            System.out.println("✅ Play Screen loaded successfully!");
        } catch (IOException e) {
            System.err.println("❌ Error loading play_screen.fxml:");
            e.printStackTrace();
        }
    }
}
