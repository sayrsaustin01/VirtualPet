<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.virtuaalpet.virtualpet.TutorialScreenController">

    <children>
        <ImageView fx:id="MyBackgroundView" fitHeight="500.0" fitWidth="800.0">
            <image>
                <Image url="@Pic/TutorialBG3.png" />
            </image>
        </ImageView>

        <!-- Next Button -->
        <Button fx:id="nextButton" layoutX="656.0" layoutY="420.0" onAction="#handleNextButton" prefHeight="50.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-background-image: url('@Pic/NextButton1preview.png');                 -fx-background-size: cover;">
        </Button>

        <!-- Back Button -->
        <Button fx:id="backButton" layoutX="49.0" layoutY="435.0" onAction="#handleBackButton" prefHeight="50.0" prefWidth="120.0" style="-fx-background-color: #ffcc00; -fx-font-size: 18px;" text="BACK">
        </Button>
      <ImageView fitHeight="131.0" fitWidth="136.0" layoutX="619.0" layoutY="405.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Pic/NextButton1preview.png" />
         </image>
      </ImageView>
    </children>
</AnchorPane>
